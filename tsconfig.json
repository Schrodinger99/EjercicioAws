{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "Node16",
    "target": "es2022",

    "types": ["node"],
    "moduleResolution": "node16",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "sourceMap": true,

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*"]
}